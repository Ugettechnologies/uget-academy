generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
  STAFF
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  passwordHash  String
  role          Role      @default(STUDENT)
  emailVerified   Boolean   @default(false)
  failedAttempts  Int       @default(0)
  lockoutUntil    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  coursesAsInstructor Course[]  @relation("InstructorCourses")
  enrollments         Enrollment[]
  payments            Payment[]
  notifications       Notification[]
  attendanceLogs      AttendanceLog[]
  activityLogs        ActivityLog[]
  dailyAttendances    DailyAttendance[]
  grades              StudentGrade[]

  lessonBookmarks       LessonBookmark[]
  lessonNotes           LessonNote[]
  assignmentSubmissions AssignmentSubmission[]
  quizAttempts          QuizAttempt[]
  certificates          Certificate[]
  liveSessionAttendances LiveSessionAttendance[]
  absenceExcuses        AbsenceExcuse[]
  forumThreads          ForumThread[]
  forumReplies          ForumReply[]
  forumUpvotes          ForumUpvote[]
  forumReports          ForumReport[]
  directQAs             DirectQA[]            @relation("StudentQA")
  announcements         Announcement[]
  sentDMs               DirectMessage[]       @relation("DMSender")
  receivedDMs           DirectMessage[]       @relation("DMReceiver")
  supportTickets        SupportTicket[]
}

model Course {
  id          String       @id @default(cuid())
  title       String
  description String
  price       Float
  published   Boolean      @default(false)
  instructorId String
  instructor  User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lessons     Lesson[]
  enrollments Enrollment[]
  dailyAttendances DailyAttendance[]
  grades           StudentGrade[]
  weeklyReports    WeeklyReport[]
  topics           CourseTopic[]
  exams            Exam[]

  assignments           Assignment[]
  quizzes               Quiz[]
  certificates          Certificate[]
  liveSessions          LiveSession[]
  forumThreads          ForumThread[]
  directQAs             DirectQA[]
  announcements         Announcement[]
  directMessages        DirectMessage[]
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  muxPlaybackId String?
  muxAssetId  String?
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendanceLogs AttendanceLog[]

  content               String?
  resources             Json?
  bookmarks             LessonBookmark[]
  notes                 LessonNote[]
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  reference     String        @unique
  method        String        // "PAYSTACK" or "MANUAL"
  receiptUrl    String?       // Cloudinary URL for manual
  status        PaymentStatus @default(PENDING)
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AttendanceLog {
  id              String   @id @default(cuid())
  userId          String
  lessonId        String
  durationSeconds Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "LOGIN" | "ENROLLED" | "WATCHED_LESSON" | "COMPLETED_LESSON" | "PAYMENT_INITIATED" | "PAYMENT_SUBMITTED" | "PAYMENT_VERIFIED"
  details   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyAttendance {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  date        DateTime
  status      String   // "PRESENT", "ABSENT", "LATE"
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, courseId, date])
}

model StudentGrade {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  score          Float    @default(0) // Overall performance score
  creativeScore  Float    @default(0) // Practical Exam score
  interviewScore Float    @default(0) // Interview score
  remarks        String?
  gradedBy       String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, courseId])
}

model WeeklyReport {
  id           String   @id @default(cuid())
  courseId     String
  instructorId String
  weekNumber   Int
  summary      String   // The text summary report
  challenges   String?  // Challenges observed
  nextSteps    String?  // Plans for next week
  submittedAt  DateTime @default(now())
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, weekNumber])
}

model CourseTopic {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  content     String   // Generated outline/material (markdown)
  videoUrl    String?  // Reference video URL if generated
  createdAt   DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Exam {
  id            String   @id @default(cuid())
  courseId      String   @unique
  practicalTask String   // Markdown description of the practical exam task
  interviewQns  String   // JSON or text representing structured interview questions
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  action    String   // e.g. 'DELETE_COURSE', 'UPDATE_USER_ROLE'
  targetId  String?  // id of the record affected, if any
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
}

model LessonBookmark {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model LessonNote {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Assignment {
  id               String                 @id @default(cuid())
  title            String
  description      String
  dueDate          DateTime
  courseId         String
  allowResubmission Boolean               @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  course           Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions      AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  userId       String
  type         String     // "FILE", "LINK", "TEXT"
  content      String
  grade        Float?
  feedback     String?
  submittedAt  DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
}

model Quiz {
  id        String        @id @default(cuid())
  title     String
  courseId  String
  questions Json          // Holds the array of questions with options and answerIndex
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts  QuizAttempt[]
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Float
  passed    Boolean
  answers   Json     // Holds user responses
  createdAt DateTime @default(now())

  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Certificate {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  certificateCode String   @unique
  issuedAt        DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LiveSession {
  id          String                  @id @default(cuid())
  courseId    String
  title       String
  startTime   DateTime
  endTime     DateTime
  sessionCode String?
  ipAddress   String?
  latitude    Float?
  longitude   Float?
  radius      Float?                  // in meters
  createdAt   DateTime                @default(now())

  course      Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendances LiveSessionAttendance[]
  excuses     AbsenceExcuse[]
}

model LiveSessionAttendance {
  id            String      @id @default(cuid())
  liveSessionId String
  userId        String
  status        String      // "PRESENT", "LATE", "ABSENT"
  checkInTime   DateTime?
  ipAddress     String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, userId])
}

model AbsenceExcuse {
  id            String      @id @default(cuid())
  liveSessionId String
  userId        String
  reason        String
  status        String      @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  resolvedBy    String?
  resolvedAt    DateTime?
  createdAt     DateTime    @default(now())

  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, userId])
}

model ForumThread {
  id        String        @id @default(cuid())
  courseId  String?       // null if academy lounge
  title     String
  content   String
  authorId  String
  isPinned  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  course    Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   ForumReply[]
  upvotes   ForumUpvote[]
  reports   ForumReport[]
}

model ForumReply {
  id               String        @id @default(cuid())
  threadId         String
  content          String
  authorId         String
  isVerifiedAnswer Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  thread           ForumThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author           User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  upvotes          ForumUpvote[]
  reports          ForumReport[]
}

model ForumUpvote {
  id        String       @id @default(cuid())
  userId    String
  threadId  String?
  replyId   String?
  createdAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread    ForumThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reply     ForumReply?  @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId, replyId])
}

model ForumReport {
  id         String       @id @default(cuid())
  reporterId String
  threadId   String?
  replyId    String?
  reason     String
  resolved   Boolean      @default(false)
  createdAt  DateTime     @default(now())

  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  thread     ForumThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reply      ForumReply?  @relation(fields: [replyId], references: [id], onDelete: Cascade)
}

model DirectQA {
  id         String    @id @default(cuid())
  courseId   String
  studentId  String
  question   String
  answer     String?
  answeredAt DateTime?
  createdAt  DateTime  @default(now())

  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    User      @relation("StudentQA", fields: [studentId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String   @id @default(cuid())
  courseId  String?  // null if academy-wide
  title     String
  content   String
  authorId  String
  createdAt DateTime @default(now())

  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model DirectMessage {
  id         String   @id @default(cuid())
  courseId   String
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())

  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sender     User     @relation("DMSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("DMReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id          String    @id @default(cuid())
  userId      String
  subject     String
  message     String
  status      String    @default("OPEN") // "OPEN", "IN_PROGRESS", "RESOLVED"
  adminReply  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

