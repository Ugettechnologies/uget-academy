generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
  STAFF
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  passwordHash  String
  role          Role      @default(STUDENT)
  emailVerified   Boolean   @default(false)
  failedAttempts  Int       @default(0)
  lockoutUntil    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  coursesAsInstructor Course[]  @relation("InstructorCourses")
  enrollments         Enrollment[]
  payments            Payment[]
  notifications       Notification[]
  attendanceLogs      AttendanceLog[]
  activityLogs        ActivityLog[]
  dailyAttendances    DailyAttendance[]
  grades              StudentGrade[]
}

model Course {
  id          String       @id @default(cuid())
  title       String
  description String
  price       Float
  published   Boolean      @default(false)
  instructorId String
  instructor  User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lessons     Lesson[]
  enrollments Enrollment[]
  dailyAttendances DailyAttendance[]
  grades           StudentGrade[]
  weeklyReports    WeeklyReport[]
  topics           CourseTopic[]
  exams            Exam[]
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  muxPlaybackId String?
  muxAssetId  String?
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendanceLogs AttendanceLog[]
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  reference     String        @unique
  method        String        // "PAYSTACK" or "MANUAL"
  receiptUrl    String?       // Cloudinary URL for manual
  status        PaymentStatus @default(PENDING)
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AttendanceLog {
  id              String   @id @default(cuid())
  userId          String
  lessonId        String
  durationSeconds Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "LOGIN" | "ENROLLED" | "WATCHED_LESSON" | "COMPLETED_LESSON" | "PAYMENT_INITIATED" | "PAYMENT_SUBMITTED" | "PAYMENT_VERIFIED"
  details   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyAttendance {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  date        DateTime
  status      String   // "PRESENT", "ABSENT", "LATE"
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, courseId, date])
}

model StudentGrade {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  score          Float    @default(0) // Overall performance score
  creativeScore  Float    @default(0) // Practical Exam score
  interviewScore Float    @default(0) // Interview score
  remarks        String?
  gradedBy       String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, courseId])
}

model WeeklyReport {
  id           String   @id @default(cuid())
  courseId     String
  instructorId String
  weekNumber   Int
  summary      String   // The text summary report
  challenges   String?  // Challenges observed
  nextSteps    String?  // Plans for next week
  submittedAt  DateTime @default(now())
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, weekNumber])
}

model CourseTopic {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  content     String   // Generated outline/material (markdown)
  videoUrl    String?  // Reference video URL if generated
  createdAt   DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Exam {
  id            String   @id @default(cuid())
  courseId      String   @unique
  practicalTask String   // Markdown description of the practical exam task
  interviewQns  String   // JSON or text representing structured interview questions
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  action    String   // e.g. 'DELETE_COURSE', 'UPDATE_USER_ROLE'
  targetId  String?  // id of the record affected, if any
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
}
